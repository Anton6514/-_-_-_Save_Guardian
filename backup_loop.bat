@echo off
setlocal EnableDelayedExpansion
:: Устанавливаем заголовок окна для удобства идентификации и завершения.
title GothicBackupLoop

:: --- ПРИЁМ АРГУМЕНТОВ ---
:: Получаем пути, переданные из первого скрипта.
set "GAME_EXE_PATH=%~1"  REM Путь к исполняемому файлу игры.
set "SAVE_DIR=%~2"       REM Путь к папке сохранений игры.
set "BACKUP_DIR=%~3"     REM Базовая папка для резервных копий.

:: --- НАСТРОЙКА ПАРАМЕТРОВ РЕЗЕРВНОГО КОПИРОВАНИЯ ---
set "INTERVAL_SECONDS=3600" REM Интервал между копиями в секундах (3600 = 1 час).
set "MAX_SLOTS=12"          REM Максимальное количество хранимых резервных копий (слотов).

:: --- ПРОВЕРКА ВХОДНЫХ ДАННЫХ ---
if not defined GAME_EXE_PATH (
    echo Не указан путь к исполняемому файлу игры. Выход.
    exit /b 1  REM Выходим с кодом ошибки 1.
)
if not defined SAVE_DIR (
    echo Не указана папка сохранений игры. Выход.
    exit /b 1
)
if not defined BACKUP_DIR (
    echo Не указана базовая папка для резервных копий. Выход.
    exit /b 1
)

:: --- ИНФОРМАЦИОННОЕ СООБЩЕНИЕ ---
echo Цикл резервного копирования запущен.
echo Интервал: !INTERVAL_SECONDS! секунд (примерно !INTERVAL_SECONDS! / 3600 = !expr !INTERVAL_SECONDS! / 3600! часов).
echo Максимальное количество слотов: !MAX_SLOTS!
echo Папка сохранений: !SAVE_DIR!
echo Папка бекапа: !BACKUP_DIR!

:loop_start
:: --- ОЖИДАНИЕ ---
:: Ждём заданное количество секунд. ping -n N ... - способ сделать задержку без активного ожидания процессора.
ping -n !INTERVAL_SECONDS! 127.0.0.1 > nul

:: --- ПРОВЕРКА СТАТУСА ИГРЫ ---
:: Проверяем, всё ли ещё запущена игра.
tasklist /FI "IMAGENAME eq %~nx1" 2>NUL | find /I /N "%~nx1">NUL
if NOT "%ERRORLEVEL%"=="0" (
    :: ERRORLEVEL не 0 означает, что find НЕ нашёл процесс игры.
    echo Игра больше не запущена. Выход из цикла резервного копирования.
    exit /b 0  REM Корректно завершаем этот скрипт.
)

:: --- СОЗДАНИЕ РЕЗЕРВНОЙ КОПИИ ---
echo [!date! !time!] Обнаружена работающая игра, создание резервной копии...

:: --- ГЕНЕРАЦИЯ УНИКАЛЬНОГО ИМЕНИ СЛОТА ---
:: Создаём временную метку в формате YYYYMMDD_HHMMSS из текущей даты и времени.
:: %date:~-4,4% - последние 4 символа даты (год). %date:~-10,2% - 2 символа начиная с 10 с конца (месяц). %date:~-7,2% - 2 символа начиная с 7 с конца (день).
:: %time:~0,2% - первые 2 символа времени (часы). %time:~3,2% - символы с 4 по 5 (минуты). %time:~6,2% - символы с 7 по 8 (секунды).
set "timestamp=%date:~-4,4%%date:~-10,2%%date:~-7,2%_%time:~0,2%%time:~3,2%%time:~6,2%"
:: Заменяем возможные пробелы в часах (если HH < 10) на '0'.
set "timestamp=!timestamp: =0!"
:: Формируем полный путь для нового слота резервной копии.
set "current_backup_slot_dir=!BACKUP_DIR!\Save_Backup_!timestamp!"

:: --- КОПИРОВАНИЕ ФАЙЛОВ ---
if exist "!SAVE_DIR!" (
    :: Используем robocopy для копирования. /E - копирует всё, включая пустые подкаталоги.
    :: /NFL /NDL /NJH /NJS - подавляют лишний лог для чистоты вывода при /L (листинге).
    robocopy "!SAVE_DIR!" "!current_backup_slot_dir!" /E /NFL /NDL /NJH /NJS >nul
    :: robocopy возвращает числовое значение в ERRORLEVEL.
    :: <= 1 обычно означает успех (0 - нет изменений, 1 - файлы скопированы).
    if !errorlevel! leq 1 (
        echo. ...Копирование завершено в !current_backup_slot_dir!.
    ) else (
        echo. ...Возможно, произошла ошибка копирования (ERRORLEVEL: !errorlevel!). Проверьте папку.
    )
) else (
    echo. ПРЕДУПРЕЖДЕНИЕ: Папка сохранений !SAVE_DIR! не найдена или пуста. Пропуск копирования.
)

:: --- УПРАВЛЕНИЕ КОЛИЧЕСТВОМ СЛОТОВ ---
:: Получаем список всех папок бекапа, начинающихся на "Save_Backup_", отсортированных по имени (хронологически, если имена по времени).
:: dir /ad - только каталоги. /b - "bare format", только имена. /o:n - сортировка по имени (ASC).
:: for /f обрабатывает вывод команды.
set index=0
for /f "delims=" %%i in ('dir "!BACKUP_DIR!\Save_Backup_*" /ad /b /o:n 2^>nul') do (
    set "folder_list[!index!]=%%i"
    set /a index+=1
)
set /a total_folders=!index!

:: --- УДАЛЕНИЕ СТАРЫХ СЛОТОВ ---
:: Если количество папок превышает максимальное количество слотов...
if !total_folders! gtr !MAX_SLOTS! (
    set /a slots_to_delete=!total_folders! - !MAX_SLOTS!
    echo Найдено !total_folders! слотов, требуется максимум !MAX_SLOTS!. Удаление !slots_to_delete! самых старых слотов.
    :: Цикл по индексам от 0 до slots_to_delete - 1. Это самые старые папки в отсортированном списке.
    for /l %%j in (0, 1, !slots_to_delete!) do (
        set "folder_to_delete=!folder_list[%%j]!"
        if defined folder_to_delete (
            echo Удаляется старый слот: !folder_to_delete!
            :: rmdir /s /q - рекурсивно (-s) и без подтверждения (-q) удаляет каталог и всё его содержимое.
            rmdir /s /q "!BACKUP_DIR!\!folder_to_delete!" 2>nul
            if !errorlevel! equ 0 (
                echo ...Успешно удалён.
            ) else (
                echo ...Ошибка удаления !folder_to_delete!. Возможно, файл заблокирован.
            )
        )
    )
)

:: --- ВОЗВРАТ К ЦИКЛУ ---
goto loop_start  REM Возвращаемся к началу цикла ожидания.
